APP_NAME="Variance Admin"
APP_VERSION=0.4.0
APP_ENV=production
APP_KEY=base64:replace-with-generated-production-key
APP_DEBUG=false
APP_URL=https://variance.unil.ch
APP_GIT_SHA=replace-with-deployed-commit-sha
ADMIN_BASE_PATH=/admin
ASSET_URL=/admin
APP_TIMEZONE=Europe/Zurich
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=variance
DB_USERNAME=variance_user
DB_PASSWORD=replace-with-secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=variance_admin_session
SESSION_DOMAIN=variance.unil.ch
SESSION_PATH=/

QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=900
CACHE_STORE=database
CACHE_PREFIX=variance_cache_
REDIS_CLIENT=phpredis
REDIS_PREFIX=variance_database_
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

LOG_CHANNEL=stack
LOG_LEVEL=warning

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=variance@unil.ch
MAIL_FROM_NAME="${APP_NAME}"

TXT_IMPORT_MODE=legacy
DB_BACKUP_TIME=03:15
DB_BACKUP_RETENTION_DAYS=14
HEALTHCHECK_DISK_WARN_GB=10
HEALTHCHECK_DISK_CRIT_GB=5
