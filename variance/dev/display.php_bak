$params = array(
	'size'	 => 'font-medium',
	'leading'  => 'lineheight-medium',
	'contrast' => 'light-bkg',
	'font'	 => 'serif',
);
if (!empty($_COOKIE['viewer_params'])) {
	$params = array_merge($params, json_decode($_COOKIE['viewer_params'], true));
} else {
	setcookie('viewer_params', json_encode($params), strtotime('next year'));
} ?>
