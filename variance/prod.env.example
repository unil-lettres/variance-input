### Production environment for the integrated legacy runtime and DB container.
### Copy to variance/.env on the deployment host and replace secret values.
### Do not commit real secrets.

MYSQL_SERVERNAME_PROD=mariadb
MYSQL_SERVERNAME_DEV=mariadb
MYSQL_DATABASE=variance
MYSQL_USER=variance_user
MYSQL_PASSWORD=replace-with-secret
MYSQL_ROOT_PASSWORD=replace-with-root-secret

PMA_ARBITRARY=1
