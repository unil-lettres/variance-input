############################################
#  OS / Editor noise                       #
############################################
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

############################################
#  Logs & runtime PIDs                     #
############################################
*.log
*.pid

############################################
#  Docker bind-mounts / volumes            #
############################################
dbdata/                 # MariaDB volume
variance_data/          # Medite & back-office runtime data

############################################
#  Uploads (generated at runtime)          #
############################################
variance/uploads/

############################################
#  Test / archive data                     #
############################################
assets/

############################################
#  Python / Medite build artefacts         #
############################################
**/__pycache__/
**/*.py[cod]
**/*.so
**/*.egg
**/*.egg-info/
**/build/
**/dist/
**/venv/
**/.venv/
**/assets/nltk_data/
!medite/app/variance/assets/
!medite/app/variance/assets/nltk_data/
!medite/app/variance/assets/nltk_data/tokenizers/
!medite/app/variance/assets/nltk_data/tokenizers/punkt_tab/
!medite/app/variance/assets/nltk_data/tokenizers/punkt_tab/**

############################################
#  Node / front-end                        #
############################################
**/node_modules/

############################################
#  Laravel / PHP runtime files             #
############################################
laravel/storage/*.key
laravel/storage/logs/
laravel/bootstrap/cache/*.php

############################################
#  Local scripts / uploads / sidecars      #
############################################
/scripts/
descr/internal/
laravel/storage/app/public/uploads/
laravel/storage/app/private/
laravel/storage/app/tmp/
laravel/public/uploads/
