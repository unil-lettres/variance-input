APP_NAME="Variance Admin"
APP_VERSION=0.4.0
APP_ENV=production
APP_KEY=base64:replace-with-generated-key
APP_DEBUG=false
APP_URL=https://plt-tst-1.unil.ch
ADMIN_BASE_PATH=/admin
ASSET_URL=/admin
APP_TIMEZONE=Europe/Zurich
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=variance
DB_USERNAME=variance_user
DB_PASSWORD=replace-with-secret

SESSION_DRIVER=database
SESSION_COOKIE=variance_admin_session
SESSION_DOMAIN=plt-tst-1.unil.ch
SESSION_PATH=/

QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=variance_cache_
REDIS_PREFIX=variance_database_
LOG_CHANNEL=stack
LOG_LEVEL=info

TXT_IMPORT_MODE=legacy
